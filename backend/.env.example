# GCP project — all BigQuery queries and BQML calls run here
GCP_PROJECT=coi-innovation-testing-8166

# BigQuery dataset containing the Google Ads tables and Gemini remote models
BQ_DATASET=google_ads_audit

# Google Ads account suffix (the number at the end of every table name)
ACCOUNT_SUFFIX=9149667192

# Authentication: use Application Default Credentials (run `gcloud auth application-default login`)
# Optionally point to a service account key file instead:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
